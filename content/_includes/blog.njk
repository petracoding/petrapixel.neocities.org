<!DOCTYPE html>
<html lang="en">
  <head>
    {% include "layout/head.njk" %}
  </head>
  <body class="{{ bodyClass }} blog-page-layout">
    <noscript id="no-js-warning"
      >Please enable JavaScript to to be able to use all functions of this
      website!</noscript
    >
    <a href="#main" id="skip-to-content-link">Skip to content</a>
    <a href="/sitemap" id="skip-to-content-link2">Go to Sitemap</a>
    <div id="content">
      <!-- ------------------------------------------------ -->
      <!-- -------------------- BUTTONS ------------------- -->
      <!-- ------------------------------------------------ -->
      {% include "layout/setting-buttons.njk" %}

      <!-- ------------------------------------------------ -->
      <!-- --------------------- HEADER ------------------- -->
      <!-- ------------------------------------------------ -->

      <header>
        <div class="header-heading">
          <a href="/"
            ><img
              src="{{ nesting }}assets/img/layout/petrapixel.png"
              aria-label="petrapixel"
              height="100"
              width="300"
          /></a>
        </div>

        <div class="blog-navigation">
          <nav>
            <ul>
              <li><a href="/">Home</a></li>
              <li>
                <a
                  href="/blog{% if testingOnLocalhost %}/index{% endif %}"
                  class="{% if title == 'blog' %}active{% endif %}"
                  >All Blog Posts</a
                >
              </li>
              <li>
                <a href="https://neocities.org/site/petrapixel" target="_blank"
                  >Follow on Neocities</a
                >
              </li>
              <li>
                <a href="/rss.xml" target="_blank" aria-label="RSS Feed">RSS</a>
              </li>
            </ul>
          </nav>
          <div class="blog-navigation__clap">
            <a
              id="clap-for-me"
              href="//clap.fc2.com/post/petrapixel/?url=https%3A%2F%2Fpetrapixel.neocities.org%2F&title=petrapixel"
              target="_blank"
              ><img
                width="80"
                height="18"
                src="//clap.fc2.com/images/button/pink/petrapixel?url=https%3A%2F%2Fpetrapixel.neocities.org%2F&amp;lang=en"
                alt="clap for me on clap.fc2.com"
              />
            </a>
          </div>
        </div>
      </header>

      <!-- ------------------------------------------------ -->
      <!-- ----------------- MAIN CONTENT ----------------- -->
      <!-- ------------------------------------------------ -->
      <main id="main" class="{{ mainClass }} custom-scrollbar">
        {{ content | safe }} {% if dateCreated %}
        <div class="blog-page-date">
          Posted {{ dateCreated }}{% if dateUpdated != dateCreated %}, Updated
          {{ dateUpdated }}{% endif %}
        </div>
        {% endif %} {% if title !== "blog" %}
        <section>
          <h2 style="height: 0px; overflow: hidden">Comments</h2>
          {% if commentsText %}
          <p>{{ commentsText | safe }}</p>
          {% endif %} {% if commentsClosed %}Comments closed due to too many
          hate messages. :(<br />If you have something (nice) to say you can
          post it on my
          <a href="https://neocities.org/site/petrapixel" target="_blank"
            >Neocities profile</a
          >.{% else %}
          <div id="c_widget">Comment Widget could not be loaded!</div>
          <script src="{{ nesting }}assets/js/comment-widget.js"></script>
          {% endif %}
        </section>
        {% endif %}
      </main>
    </div>

    <!-- Lightbox -->
    {% if lightbox %}
    <script src="../assets/js/fslightbox.js"></script>
    {% endif %}
  </body>
</html>
