---
testingOnLocalhost: false
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <title>
      {{ title }}{% if title !== "Indie Web DB" %} | Indie Web DB{% endif %}
    </title>
    <meta
      name="description"
      content="{{ description or 'A database of indie websites, made by Petrapixel.' }}"
    />
    <script src="../assets/js/indieWebDB.js{{ nocache }}"></script>
    <link rel="stylesheet" href="../assets/indieWebDB.css{{ nocache }}" />
    <meta content="text/html;charset=utf-8" http-equiv="Content-Type" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="../assets/img/favicon.ico" rel="icon" type="image/x-icon" />

    <!-- Google tag (gtag.js)
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-J64TL8KVTJ"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-J64TL8KVTJ");
    </script>
	 --></head>
  <body class="{{ bodyClass }} indie-web-db">
    <noscript id="no-js-warning"
      >Please enable JavaScript to be able to use all functions of this
      website!</noscript
    >
    <a href="#main" id="skip-to-content-link">Skip to content</a>

    <!-- ------------------------------------------------ -->
    <!-- --------------------- HEADER ------------------- -->
    <!-- ------------------------------------------------ -->

    <header>
      <div class="page-title">
        Indie Web Database<small
          >by
          <a href="https://petrapixel.neocities.org/" target="_blank"
            >petrapixel</a
          ></small
        >
      </div>
      <nav class="navigation">
        <ul>
          <li><a href="/indiewebdb" class="active">Home</a></li>
          <li><a href="/indiewebdb/websites">Websites</a></li>
          <li><a href="/indiewebdb/webrings">Webrings</a></li>
          <li><a href="/indiewebdb/cliques">Cliques</a></li>
          <li><a href="/indiewebdb/random">Random</a></li>
        </ul>
      </nav>
    </header>

    <!-- ------------------------------------------------ -->
    <!-- ----------------- MAIN CONTENT ----------------- -->
    <!-- ------------------------------------------------ -->

    <main id="main" class="{{ mainClass }}">{{ content | safe }}</main>

    <!-- ------------------------------------------------ -->
    <!-- ----------------- FOOTER ----------------- -->
    <!-- ------------------------------------------------ -->

    <footer>
      <blockquote class="footer-fact">
        <b>Did you know?</b>
        <span
          >This site's cursors are
          <a href="https://www.cursors-4u.com/cursor/ubuntu-set" target="_blank"
            >Ubuntu cursors</a
          >!</span
        >
      </blockquote>
      <ul>
        <li><a href="/indiewebdb">About</a></li>
        <li><a href="/indiewebdb/contribute">Contribute</a></li>
        <li>
          <a href="https://ko-fi.com/petrastipjar" target="_blank">Donate</a>
        </li>
      </ul>
    </footer>
  </body>
</html>
