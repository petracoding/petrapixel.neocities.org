---
testingOnLocalhost: false
---

<!DOCTYPE html>
<html lang="en">
  <head>
    {% include "layout/head.njk" %}
  </head>
  <body
    class="{{ bodyClass }}"
    {%
    if
    freezeframe
    %}onload="new Freezeframe();"
    {%
    endif
    %}
  >
    <noscript id="no-js-warning"
      >Please enable JavaScript to to be able to use all functions of this
      website!</noscript
    >
    <a href="#main" id="skip-to-content-link">Skip to content</a>
    <a href="/sitemap" id="skip-to-content-link2">Go to Sitemap</a>
    <div
      style="
        display: flex;
        flex-direction: column;
        width: 100%;
        align-items: center;
      "
    >
      <div id="content">
        <!-- ------------------------------------------------ -->
        <!-- -------------------- BUTTONS ------------------- -->
        <!-- ------------------------------------------------ -->
        {% include "layout/setting-buttons.njk" %}

        <!-- ------------------------------------------------ -->
        <!-- --------------------- HEADER ------------------- -->
        <!-- ------------------------------------------------ -->

        <header>
          <div class="header-heading">
            <a href="/"
              ><img
                src="{{ nesting }}assets/img/layout/petrapixel.png"
                aria-label="petrapixel"
                height="100"
                width="300"
            /></a>
          </div>
        </header>
        <aside class="aside aside--left" data-nosnippet="true">
          <details id="mobile-nav">
            <summary id="mobile-nav-toggle">Open Navigation</summary>
            {% include "layout/nav.njk" %}
          </details>
          {% include "layout/nav.njk" %}

          <div class="aside-dreamland desktop-only">
            <!-- ----------------------------------------- -->
            <!-- ----------------- LEFT ----------------- -->
            <!-- ----------------------------------------- -->

            <!-- ----------------- SEARCHBAR ----------------- 

          <script
            async
            src="https://cse.google.com/cse.js?cx=d0371551e40124126"
          ></script>
          <div class="gcse-search"></div>
-->
            <img
              src="{{ nesting }}assets/img/layout/divider1.gif"
              alt=""
              aria-hidden="true"
            />

            <!-- ----------------- SUPPORTERS ----------------- -->

            {% include "layout/sidebars/supporters.njk" %}

            <img
              src="{{ nesting }}assets/img/layout/divider6.gif"
              alt=""
              aria-hidden="true"
              style="margin-top: -5px"
            />

            <!-- ----------------- CONTEST -----------------     

          <div class="aside-box aside-indie-web-contest" aria-hidden="true">
            <div class="aside-box__heading" aria-hidden="true">
              Contest<img
                src="{{ nesting }}assets/img/layout/icon-medal.png"
                alt=""
                aria-hidden="true"
              />
            </div>

            <a class="aside-contest" href="/contest">
              <img
                src="{{ nesting }}assets/img/layout/trophy.gif"
                width="80"
                height="85"
                alt="Trophy"
              />
              <div><b>Indie Web Contest</b><small>View Winners</small></div>
            </a>
          </div>

          -->

            <!-- ----------------- LINK BACK ----------------- -->

            {% include "layout/sidebars/link-back.njk" %}

            <!-- ----------------- CHANGELOG ----------------- -->

            <div class="aside-box aside-changelog">
              <div class="aside-box__heading" aria-hidden="true">
                Changelog<img
                  src="{{ nesting }}assets/img/layout/icon-code.png"
                  alt=""
                  aria-hidden="true"
                />
              </div>
              <ul class="changelog custom-scrollbar" aria-label="Changelog">
                {% for changelogEntry in changelog %} {% if changelogEntry.text
                != "TEMPLATE" %}
                <li class="changelog__entry">
                  <strong>{{ changelogEntry.date }}</strong>
                  {% if changelogEntry.link == "" %}
                  <span>{{ changelogEntry.text }}</span>
                  {% else %}
                  <a href="{{ changelogEntry.link }}" tabindex="-1"
                    >{{ changelogEntry.text }}</a
                  >
                  {% endif %}
                </li>
                {% endif %} {% endfor %}
              </ul>
            </div>

            <img
              src="{{ nesting }}assets/img/layout/divider8.gif"
              alt=""
              aria-hidden="true"
              style="padding-top: 5px"
            />

            <!-- ----------------- BLINKIES ----------------- -->

            <div class="aside-box aside-blinkies" aria-hidden="true">
              <marquee class="marquee aside-blinkies__buttons" scrollamount="5">
                {% include 'layout/sidebars/blinkies-blinkies.njk' %}
              </marquee>
              <marquee
                class="marquee aside-blinkies__blinkies"
                scrollamount="4"
              >
                {% include 'layout/sidebars/blinkies-buttons.njk' %}
              </marquee>
              <div id="afterneighbours">
                Click <a href="/about/blinkies">here</a> to view them all.
              </div>
            </div>

            <img
              src="{{ nesting }}assets/img/layout/divider6.gif"
              alt=""
              aria-hidden="true"
              style="margin-top: -5px"
            />

            <img
              src="{{ nesting }}assets/img/layout/divider7.gif"
              alt=""
              aria-hidden="true"
              style="padding-top: 10px"
            />

            <!-- ----------------- NAV LINK ----------------- -->

            <div class="aside-box aside-poll">
              <div class="aside-box__heading" aria-hidden="true">
                Other Sites<img
                  src="{{ nesting }}assets/img/layout/icon-hearts.png"
                  alt=""
                  aria-hidden="true"
                />
              </div>
              <!--
              <iframe
                class="aside-navlinkads"
                width="170"
                height="170"
                style="border: none"
                src="https://dimden.neocities.org/navlink/"
                name="neolink"
                aria-label="Navlink"
                loading="lazy"
              ></iframe> -->
              <center>
                <iframe
                  width="88"
                  height="31"
                  style="border: none"
                  src="https://melonsoda.nekoweb.org/button.html"
                  name="buttonlink"
                  loading="lazy"
                ></iframe>
              </center>
              <center style="line-height: 1">
                <small
                  >These are "ads" to other indie web sites. You should check
                  them out :)</small
                >
              </center>
            </div>

            <!-- ----------------- GIF ----------------- -->
            <div class="aside-box aside-gif">
              <img
                src="https://i.pinimg.com/originals/3a/c3/6c/3ac36c66ea24d4ec5f0104c982d97822.gif"
                alt="Mabel from Gravity Falls"
                title="Mabel from Gravity Falls"
              />
            </div>
            <img
              src="{{ nesting }}assets/img/layout/divider3.gif"
              alt=""
              aria-hidden="true"
              style="margin-top: -1px"
            />
          </div>
        </aside>

        <!-- ----------------------------------------- -->
        <!-- ----------------- RIGHT ----------------- -->
        <!-- ----------------------------------------- -->

        <aside class="aside aside--right desktop-only" data-nosnippet="true">
          <!-- DINOS -->
          {% include "layout/dinos.njk" %}

          <!-- ----------------- FOLLOW, GUESTBOOK, CLAP ----------------- -->
          {% include "layout/sidebars/kirby.njk" %}

          <img
            src="{{ nesting }}assets/img/layout/divider2.gif"
            alt=""
            aria-hidden="true"
            style="image-rendering: pixelated"
          />

          <!-- ----------------- STATS / STATUS ----------------- -->

          {% include "layout/sidebars/hits-visitors.njk" %}

          <div class="aside-box">
            <div class="aside-box__heading">
              <span>currently</span
              ><img
                src="{{ nesting }}assets/img/layout/icon-happy.png"
                alt=""
                aria-hidden="true"
              />
            </div>
            <div class="aside-stats__stat-content" id="statuscafe">
              <div id="statuscafe-username"></div>
              <div id="statuscafe-content"></div>
            </div>

            <ul class="aside-currently-list">
              <li aria-label="listening to:">
                <img
                  src="{{ nesting }}assets/img/layout/icon-music.png"
                  alt=""
                  title="listening to:"
                  aria-hidden="true"
                />
                <a
                  href="https://www.last.fm/user/Petra1999"
                  target="_blank"
                  id="song"
                  >various</a
                >
                <img
                  src="{{ nesting }}assets/img/layout/equalizer.gif"
                  alt=""
                  aria-hidden="true"
                />
              </li>
              <li aria-label="watching:">
                <img
                  src="{{ nesting }}assets/img/layout/icon-tv.png"
                  alt=""
                  title="watching:"
                  aria-hidden="true"
                />
                <a href="https://app.tvtime.com/user/33116783" target="_blank"
                  >Our Flag Means Death
                  <span style="font-family: sans-serif; font-size: 0.9em"
                    >↺</span
                  >, Scrubs (2026)<!----></a
                >
              </li>
              <li aria-label="reading:">
                <img
                  src="{{ nesting }}assets/img/layout/icon-book.png"
                  alt=""
                  title="reading:"
                  aria-hidden="true"
                />
                <a
                  href="https://www.goodreads.com/user/show/62158941-petra"
                  target="_blank"
                  >The Anxious Generation
                  <!--<span style="font-family: sans-serif; font-size: 0.9em">↺</span
                >--></a
                >
              </li>
              <li aria-label="playing:">
                <img
                  src="{{ nesting }}assets/img/layout/icon-game.png"
                  alt=""
                  title="playing:"
                  aria-hidden="true"
                />
                <a href="https://www.backloggd.com/u/Petra1999/" target="_blank"
                  >Slime Rancher</a
                >
              </li>

              <!--
            <li aria-label="obsessed with:">
              <img
                src="{{ nesting }}assets/img/layout/icon-heart.png"
                alt=""
                title="obsessed with:"
                aria-hidden="true"
              />
              <span
                >My cat, Holly</span
              >
            </li>
             -->
            </ul>
          </div>

          <img
            src="{{ nesting }}assets/img/layout/divider3.gif"
            alt=""
            aria-hidden="true"
            style="margin-top: -2px"
          />

          <!-- ----------------- TIP JAR ----------------- -->
          {% include "layout/sidebars/tip-jar.njk" %}

          <img
            src="{{ nesting }}assets/img/layout/divider4.gif"
            alt=""
            aria-hidden="true"
            style="padding-top: 5px"
          />

          <!-- ----------------- NEIGHBORS ----------------- -->

          <div
            class="aside-box aside-mutuals"
            data-nesting="{{ nesting }}"
            aria-hidden="true"
          >
            <div class="aside-box__heading">
              <a href="/about/neighbors"
                >Neighbors<img
                  src="{{ nesting }}assets/img/layout/icon-building.png"
                  alt=""
                  aria-hidden="true"
              /></a>
            </div>
            <a href="#afterneighbours" class="skiplink" aria-hidden="true"
              >Skip neighbours</a
            >
            <div id="beforeneighbours"></div>
            <marquee class="marquee aside-mutuals__buttons" scrollamount="5">
              {% for site in sites %} {% if site.title != "TEMPLATE" and
              site.neighbor and not site.hide %}
              <a
                href="{{ site.link }}"
                title="{{ site.title }}"
                target="_blank"
              >
                <img
                  src="{{ site.image | prepareImageUrl }}"
                  alt="{{ site.title }}"
                  width="88"
                  height="31"
                  loading="lazy"
                />
              </a>
              {% endif %} {% endfor %}
            </marquee>
            <div id="afterneighbours">
              Click <a href="/about/neighbors">here</a> to view them all.
            </div>
            <a href="#beforeneighbours" class="skiplink" aria-hidden="true"
              >Skip to before neighbours</a
            >
          </div>

          <img
            src="{{ nesting }}assets/img/layout/divider6.gif"
            alt=""
            aria-hidden="true"
            style="margin-top: -5px"
          />

          <img
            src="{{ nesting }}assets/img/layout/divider5.gif"
            alt=""
            aria-hidden="true"
            style="margin-top: 2em"
          />

          <!-- ----------------- TUMBLR ----------------- -->

          <div class="aside-box aside-tumblr" aria-hidden="true">
            <div class="aside-box__heading" aria-hidden="true">
              Tumblr<img
                src="{{ nesting }}assets/img/layout/icon-redo.png"
                alt=""
                aria-hidden="true"
              />
            </div>
            <div>
              <b>Got tumblr?</b> Reblog my
              <a
                href="https://www.tumblr.com/petrapixel/801488583310606336"
                target="_blank"
                >indie web masterpost</a
              >!
              <img
                aria-hidden="true"
                src="{{ nesting }}assets/img/inline/small-heart.gif"
              />
            </div>
          </div>

          <img
            src="{{ nesting }}assets/img/layout/divider1.gif"
            alt=""
            aria-hidden="true"
          />

          <!-- ----------------- POLL ----------------- -->

          <div class="aside-box aside-poll" aria-hidden="true">
            <div class="aside-box__heading" aria-hidden="true">
              Poll<img
                src="{{ nesting }}assets/img/layout/icon-stats.png"
                alt=""
                aria-hidden="true"
              />
            </div>

            {% include "layout/sidebars/poll.njk" %}

            <center>
              <small>(all polls <a href="/fun/polls">here</a>)</small>
            </center>
          </div>

          <!-- ----------------- TAMANOTCHI ----------------- -->

          <div class="aside-tamanotchi">
            <img src="{{ nesting }}assets/img/layout/tamagotchi.png" alt="" />
            <a href="https://tamanotchi.world/25005c"
              ><img
                src="https://tamanotchi.world/i2/25005"
                alt="It's tamaNOTchi! Click to feed!"
            /></a>
          </div>

          <!-- ----------------- CHATBOX ----------------- -->

          <!--<div class="aside-box aside-chatbox">
          <div class="aside-box__heading" aria-hidden="true" style="z-index: 2">
            Chatbox<img
              src="{{ nesting }}assets/img/layout/icon-chat.png"
              alt=""
              aria-hidden="true"
            />
          </div>
          <div>
            Closed due to spam :[ Please use the
            <a href="/about/guestbook">guestbook</a> instead.
          </div>
         <iframe
            src="https://www5.cbox.ws/box/?boxid=949361&boxtag=Asuhlk"
            width="100%"
            height="300"
            allowtransparency="yes"
            allow="autoplay"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            scrolling="auto"
            aria-label="Chatbox"
            tabindex="-1"></iframe>
        </div>
-->

          <!-- ------------------------------------------------ -->
          <!-- ------------------------------------------------ -->
          <!-- ------------------------------------------------ -->
        </aside>

        <!-- ----------------- BACK TO TOP ----------------- -->
        {% include "layout/back-to-top.njk" %}

        <!-- ----------------- CORNER IMAGES ----------------- -->
        {% include "layout/corner-images.njk" %}

        <!-- ------------------------------------------------ -->
        <!-- ----------------- MAIN CONTENT ----------------- -->
        <!-- ------------------------------------------------ -->
        <main id="main" class="{{ mainClass }}">{{ content | safe }}</main>
      </div>

      <!-- ------------------------------------------------ -->
      <!-- ----------------- FOOTER ----------------- -->
      <!-- ------------------------------------------------ -->
      {% include "layout/footer.njk" %}
    </div>
    <!-- Audios -->
    {% include "layout/audios.njk" %}

    <!-- Scripts -->
    {% if lightbox %}
    <script src="../assets/js/fslightbox.js"></script>
    {% endif %}
  </body>
</html>
